{
  "name": "rag-app",
  "version": "1.0.0",
  "description": "Production-ready RAG application with Express, LangChain, Groq, local JSON vectors, and SQL Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['node_modules','package-lock.json']) fs.rmSync(p,{recursive:true,force:true});\""
  },
  "engines": {
    "node": "22.x"
  },
  "keywords": [
    "rag",
    "langchain",
    "groq",
    "pdf"
  ],
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^0.3.42",
    "@langchain/core": "^0.3.57",
    "@langchain/groq": "^0.2.3",
    "@langchain/textsplitters": "^0.1.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "langchain": "^0.3.27",
    "mammoth": "^1.9.0",
    "minisearch": "^7.1.2",
    "mssql": "^11.0.1",
    "multer": "^1.4.5-lts.2",
    "officeparser": "^5.1.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  }
}
